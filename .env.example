# Environment Variables — Cynaptics Website
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.

# ──────────────────────────────────────────────
# EXISTING (Firebase)
# ──────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# ──────────────────────────────────────────────
# EXISTING (Cloudinary)
# ──────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ──────────────────────────────────────────────
# NEW — Phase A: NextAuth / Google OAuth
# ──────────────────────────────────────────────

# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=

# In development: http://localhost:3001 (adjust port if needed)
# In production:  https://your-deployed-domain.vercel.app
NEXTAUTH_URL=http://localhost:3001

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────
# NEW — Phase B: AWS S3
# ──────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=cynaptics-blogs
# Public base URL of your S3 bucket (or CloudFront distribution URL)
NEXT_PUBLIC_S3_BASE_URL=https://<bucket>.s3.<region>.amazonaws.com
